# Database
POSTGRES_URL=

# Cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# LLM — set LLM_PROVIDER to choose which one (anthropic | gemini | openrouter)
# OpenRouter is recommended: free tier, multi-model, no billing required
LLM_PROVIDER=openrouter
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Domain APIs
NAMECRAWL_API_KEY=
GODADDY_API_KEY=
GODADDY_API_SECRET=

# Product Hunt
PRODUCT_HUNT_API_KEY=
PRODUCT_HUNT_API_SECRET=

# Cron security
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
